[application]

config/name="Turtleburg"
run/main_scene="res://Scenes/Start Menu.tscn"
config/use_custom_user_dir=true
config/icon="res://Sprites/icon.png"

[autoload]

Global="*res://Scripts/Global.gd"
Load="*res://Scripts/load.gd"
DialogueManager="*res://addons/dialogue_manager/dialogue_manager.gd"

[display]

window/size/width=1280
window/size/height=720
window/stretch/mode="2d"
window/stretch/aspect="keep"

[editor_plugins]

enabled=PoolStringArray( "res://addons/dialogic/plugin.cfg", "res://addons/dialogue_manager/plugin.cfg" )

[global]

input=false

